DATABASE_URL=mysql+pymysql://root:change-me@mysql:3306/tickets_db
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=tickets_db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true

APP_NAME=tickets_api
ENV=production
DEBUG=false
FRONTEND_PUBLIC_URL=https://tickets.example.com
UVICORN_WORKERS=2

JWT_SECRET_KEY=replace-with-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

REDIS_URL=redis://tickets_redis:6379
REDIS_CONNECT_RETRY_SECONDS=30

ALLOWED_ORIGINS=["https://tu-frontend.com"]
CORS_ALLOW_ORIGIN_REGEX=

GZIP_ENABLED=true
GZIP_MINIMUM_SIZE_BYTES=1024
GZIP_COMPRESSLEVEL=6

RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_REQUESTS=120
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_REQUESTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_CREATE_ORDER_REQUESTS=20
RATE_LIMIT_CREATE_ORDER_WINDOW_SECONDS=60
RATE_LIMIT_CREATE_PAYMENT_REQUESTS=20
RATE_LIMIT_CREATE_PAYMENT_WINDOW_SECONDS=60
RATE_LIMIT_GET_PAYMENT_REQUESTS=120
RATE_LIMIT_GET_PAYMENT_WINDOW_SECONDS=60
RATE_LIMIT_TRUST_X_FORWARDED_FOR=false

MEDIA_ROOT=media
MEDIA_URL_PATH=/media
UPLOAD_MAX_IMAGE_SIZE_MB=5

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Tickets Nova
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

CROSSMINT_ENV=production
CROSSMINT_HOST=https://www.crossmint.com
CROSSMINT_SERVER_SIDE_API_KEY=
CROSSMINT_CLIENT_SIDE_API_KEY=
CROSSMINT_ORDERS_BASE_URL=https://www.crossmint.com/api/2022-06-09
CROSSMINT_USERS_BASE_URL=https://www.crossmint.com/api/2025-06-09
CROSSMINT_RECIPIENT_USER_EMAIL=
CROSSMINT_RECIPIENT_WALLET_ADDRESS=
CROSSMINT_RECIPIENT_CHAIN=solana
CROSSMINT_TOKEN_LOCATOR=solana:EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
CROSSMINT_PAYMENT_METHOD=checkoutcom-flow
CROSSMINT_SUPPORT_WHATSAPP=
